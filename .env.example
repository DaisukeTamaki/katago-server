# KataGo binary -- "katago" if installed via brew/PATH, or absolute path
KATAGO_KATAGO_BINARY=katago

# Analysis engine config (checked into repo)
KATAGO_ANALYSIS_CONFIG=config/analysis.cfg

# Neural network model -- download from https://github.com/lightvector/KataGo/releases
KATAGO_MODEL_PATH=models/default.bin.gz

# Optional: human SL model for human-level analysis
# KATAGO_HUMAN_MODEL_PATH=models/b18c384nbt-humanv0.bin.gz

# Server settings
KATAGO_HOST=0.0.0.0
KATAGO_PORT=8000
